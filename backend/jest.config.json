{
  "testEnvironment": "node",
  "testMatch": ["**/__tests__/**/*.test.js"],
  "collectCoverageFrom": [
    "src/**/*.js",
    "!src/server.js",
    "!src/config/migrate.js",
    "!src/config/seed.js"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 10,
      "functions": 10,
      "lines": 30,
      "statements": 30
    }
  },
  "testTimeout": 15000
}
